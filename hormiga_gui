import pygame
import hormiga_logica as hor
import easygui

tick = 60

def pedir_entero(mensaje):
    """Solicita un numero entero positivo usando easygui.
    Entradas y restricciones:
    - mensaje: texto que se muestra al usuario.
    Salida:
    - Número entero positivo.
    """
    while True:
        texto = easygui.enterbox(mensaje)

        if texto == None:
            easygui.msgbox("Debe ingresar un número.")
        else:
            try:
                numero = int(texto)
                if numero > 0:
                    return numero
                easygui.msgbox("Debe ingresar un número mayor que cero.")
            except Exception:
                easygui.msgbox("Debe ingresar un número entero válido.")

        pygame.display.update()
        clock.tick(tick)

    pygame.quit()


if __name__ == "__main__":
    main()
